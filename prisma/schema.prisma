generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProcessingStatus {
  pending
  processing
  indexed
  failed
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  name      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  datasets      Dataset[]
  conversations AIConversation[]

  @@index([email])
  @@map("users")
}

model Dataset {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  description String?
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  uploadedFiles UploadedFile[]

  @@index([userId])
  @@index([createdAt])
  @@map("datasets")
}

model UploadedFile {
  id               String           @id @default(uuid()) @db.Uuid
  filename         String
  mimeType         String?          @map("mime_type")
  size             Int?
  storagePath      String?          @map("storage_path")
  processingStatus ProcessingStatus @default(pending) @map("processing_status")
  errorMessage     String?          @map("error_message") @db.Text
  chunkCount       Int?             @map("chunk_count")
  rowCount         Int?             @map("row_count")
  cleanedRowCount  Int?             @map("cleaned_row_count")
  sheetName        String?          @map("sheet_name")
  datasetId        String           @map("dataset_id") @db.Uuid
  dataset          Dataset          @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  fileSheets      FileSheet[]
  cleaningReports CleaningReport[]

  @@index([datasetId])
  @@index([processingStatus])
  @@map("uploaded_files")
}

model FileSheet {
  id             String       @id @default(uuid()) @db.Uuid
  fileId         String       @map("file_id") @db.Uuid
  file           UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sheetName      String?      @map("sheet_name")
  headers        Json
  cleaningConfig Json?        @map("cleaning_config")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  rows FileRow[]

  @@index([fileId])
  @@map("file_sheets")
}

model FileRow {
  id       String    @id @default(uuid()) @db.Uuid
  sheetId  String    @map("sheet_id") @db.Uuid
  sheet    FileSheet @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  rowIndex Int       @map("row_index")
  data     Json

  @@index([sheetId, rowIndex])
  @@map("file_rows")
}

model CleaningReport {
  id                String       @id @default(uuid()) @db.Uuid
  fileId            String       @map("file_id") @db.Uuid
  file              UploadedFile @relation(fields: [fileId], references: [id], onDelete: Cascade)
  sheetId           String?      @map("sheet_id") @db.Uuid
  originalRowCount  Int          @map("original_row_count")
  cleanedRowCount   Int          @map("cleaned_row_count")
  duplicatesRemoved Int          @map("duplicates_removed")
  emptyRowsRemoved  Int          @map("empty_rows_removed")
  cellsTrimmed      Int          @default(0) @map("cells_trimmed")
  cleaningConfig    Json         @map("cleaning_config")
  appliedAt         DateTime     @default(now()) @map("applied_at")

  @@index([fileId])
  @@map("cleaning_reports")
}

model AIConversation {
  id        String   @id @default(uuid()) @db.Uuid
  title     String?
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  queries AIQuery[]

  @@index([userId])
  @@index([createdAt])
  @@map("ai_conversations")
}

model AIQuery {
  id             String         @id @default(uuid()) @db.Uuid
  prompt         String         @db.Text
  response       String?        @db.Text
  conversationId String         @map("conversation_id") @db.Uuid
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_queries")
}
