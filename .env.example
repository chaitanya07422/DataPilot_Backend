# Copy for local development: cp .env.example .env

NODE_ENV=development
PORT=3001
HOST=127.0.0.1
LOG_LEVEL=info
DATABASE_URL=postgresql://datapilot:datapilot@localhost:5432/datapilot?schema=public
REDIS_HOST=localhost
REDIS_PORT=6380
QDRANT_URL=http://localhost:6335
CORS_ORIGIN=http://localhost:3000

UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=20971520
LOCAL_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
QDRANT_COLLECTION=datapilot_documents
DEV_USER_ID=00000000-0000-4000-8000-000000000001

# Bull Board queue dashboard (http://localhost:3001/admin/queues)
BULL_BOARD_ENABLED=true
BULL_BOARD_PATH=/admin/queues
